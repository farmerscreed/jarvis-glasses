# Provider keys for the Edge Functions (local dev). Copy to `.env` and fill in.
# SUPABASE_URL / SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY are injected automatically by the CLI.

ANTHROPIC_API_KEY=sk-ant-...

# --- Embeddings: Google Gemini (free tier). Output dim must match memories.embedding (1536). ---
EMBED_PROVIDER=gemini
GEMINI_API_KEY=AIza...
GEMINI_EMBED_MODEL=gemini-embedding-001
EMBED_DIM=1536

# OpenAI fallback (set EMBED_PROVIDER=openai to use):
OPENAI_API_KEY=sk-...
EMBED_MODEL=text-embedding-3-small

CLAUDE_MODEL=claude-sonnet-4-6
