# JARVIS Agent Bridge config. Copy to `agent-bridge/.env` (gitignored).
# Generate a token:  node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"

# Shared bearer token the app must send as: Authorization: Bearer <token>.
# If empty, the bridge runs open (localhost-only) — fine for first local tests, set one for real use.
BRIDGE_TOKEN=

# Port the bridge listens on (127.0.0.1 only). Phone reaches it via: adb reverse tcp:8765 tcp:8765
BRIDGE_PORT=8765

# Default working directory for tasks (defaults to the repo root).
# BRIDGE_DEFAULT_CWD=C:\Users\admin\Documents\APP\jarvis

# Default allowed tools when a task doesn't specify (research preset: read-only + web).
# BRIDGE_DEFAULT_TOOLS=WebSearch,WebFetch,Read,Glob,Grep

# Override the claude executable path (auto-detected via PATH if unset).
# CLAUDE_BIN=C:\Users\admin\.local\bin\claude.exe
